# === Meta / Instagram (cargar en n8n como variables de entorno) ===
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_ACCOUNT_ID=
META_APP_ID=
META_APP_SECRET=

# === Canva (opcional, si se usa el MCP/API) ===
CANVA_API_KEY=

# === NanoBanana / Nano Banana Pro (imágenes IA hero — portadas y cierres) ===
# API key de Google Gemini Image. Default gemini-3-pro-image-preview (Nano Banana Pro).
NANOBANANA_API_KEY=
# NANOBANANA_MODEL=gemini-3-pro-image-preview   # alternativo: gemini-2.5-flash-image

# === n8n (si se usa webhook/trigger) ===
N8N_WEBHOOK_URL=
N8N_API_KEY=
